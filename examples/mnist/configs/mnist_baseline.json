{
  "_documentation": "Baseline VIBMask on digits-MNIST WITHOUT the optional extensions. Useful as a control to measure what V14-A adds. Uses the paper's core training loop (β, γ, K selectors, regulariser warmup, EMA, cosine LR) but none of the MNIST-specific priors, multi-k loss, patch dilation, or Lasso rerank. Expected to lag substantially behind V14-A at low k.",
  "dataset": "mnist",
  "n_train": 60000,
  "n_test": 10000,
  "n_seeds": 3,
  "eval_ks": [5, 10, 20, 30, 50],
  "eval_patch_kernel": 3,
  "use_lasso_rerank": false,
  "prior_blend": 0.0,
  "train_config": {
    "batch_size": 128,
    "val_fraction": 0.1,
    "learning_rate": 1e-3,
    "weight_decay": 1e-4,
    "max_iters": 5000,
    "early_stop_patience": 2000,
    "num_selectors": 3,
    "sigma": 0.5,
    "train_sigma": false,
    "sel_hidden": [200, 200],
    "pred_hidden": [200, 200, 200],
    "layer_norm": true,
    "activation": "relu",
    "pred_dropout": 0.0,
    "beta": 1.0,
    "gamma": 1.0,
    "warmup_iters": 500,
    "gate_type": "hard_concrete",
    "hc_beta": 0.5,
    "ema_decay": 0.99,
    "lr_schedule": "cosine",
    "label_smoothing": 0.0,
    "grad_clip": 1.0,
    "bootstrap": true,
    "log_every": 1000,
    "device": "cpu"
  }
}
